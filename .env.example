# ===== WhatsApp Cloud API (هتاخدهم من Meta App → WhatsApp → API Setup) =====
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# ده انت اللي بتخترعه (أي نص عشوائي قوي)، وبتحطه هنا وفي خانة Verify Token في Meta برضه
WHATSAPP_VERIFY_TOKEN=

# ===== قاعدة البيانات (SQL Server) =====
DB_NAME=ChatwootReports
DB_PASSWORD=
DB_PORT=1433
DB_SERVER=
DB_TDS_VERSION=4.2
DB_USER=

# اسم الجدول اللي هيتخزن فيه كل رسائل الواتساب
DB_TABLE_NAME=NileChat_byA

# مفتاح سري لتشفير جلسات تسجيل الدخول (اخترع نص عشوائي طويل وقوي)
JWT_SECRET=

# مفتاح سري لإنشاء أول موظف مرة واحدة بس عن طريق /api/setup/first-agent
SETUP_SECRET=

# ===== دومين الداشبورد بتاعك (عشان CORS) =====
DASHBOARD_ORIGIN=https://support.niletechno.com

# ===== دومين المشروع الثابت (بيتستخدم في لينك تحديد كلمة السر ولينك اللوجو في إيميل الدعوة) =====
# لازم يكون نفس الدومين اللي بتبعت منه على Resend (أو subdomain منه) عشان الإيميل مايروحش سبام
# مثال: https://app.abdullahelsawy.online (من غير / في الآخر)
APP_URL=https://app.abdullahelsawy.online

# ===== إرسال إيميلات دعوة الإيجنتس الجدد عن طريق Resend (https://resend.com) =====
# لو سيبته فاضي، هيتم طباعة لينك الدعوة في اللوج بس من غير إيميل حقيقي (وضع تطوير)
RESEND_API_KEY=
# لازم يكون من دومين متأكد منه (Verified) في حساب Resend بتاعك، وإلا استخدم onboarding@resend.dev للتجربة
MAIL_FROM=NileChat <onboarding@resend.dev>

PORT=3000
